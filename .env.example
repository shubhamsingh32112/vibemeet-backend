############################################
# Backend env template (DO NOT put secrets in git)
############################################

# Runtime
NODE_ENV=production
PORT=3000
TRUST_PROXY_HOPS=1

# Process role (unset = monolith in non-production only; required in production)
# Values: api-ws | billing-worker | moments-worker | image-worker | monolith
# SERVICE_ROLE=api-ws
# Legacy alias: ECS_SERVICE_ROLE (prefer SERVICE_ROLE)

# Per-service tuning (when split on ECS — same image, different env blocks):
#
# api-ws-service:
#   SERVICE_ROLE=api-ws
#   SOCKET_IO_REDIS_ADAPTER=true
#   MONGO_POOL_SIZE=40
#   USE_MOMENTS=true
#   USE_CLOUDFLARE_IMAGES=true
#
# billing-worker-service:
#   SERVICE_ROLE=billing-worker
#   SOCKET_IO_REDIS_ADAPTER=true
#   BILLING_BULLMQ_CONCURRENCY=50
#   MONGO_POOL_SIZE=25
#   USE_MOMENTS=false
#   USE_CLOUDFLARE_IMAGES=false
#
# moments-worker-service:
#   SERVICE_ROLE=moments-worker
#   USE_MOMENTS=true
#   SOCKET_IO_REDIS_ADAPTER=false
#   MONGO_POOL_SIZE=12
#
# image-worker-service:
#   SERVICE_ROLE=image-worker
#   USE_CLOUDFLARE_IMAGES=true
#   SOCKET_IO_REDIS_ADAPTER=false
#   MONGO_POOL_SIZE=8
#   BLURHASH_CONCURRENCY=2
#
# Graceful shutdown (optional):
# SHUTDOWN_HTTP_MS=30000
# SHUTDOWN_BULLMQ_MS=60000

# Public URLs (used to build web checkout links)
# This MUST be your public API base including /api/v1
PUBLIC_API_BASE_URL=https://api.prestigeinteriordesign.com/api/v1

# This MUST be the public website host that serves /wallet-checkout
WEB_CHECKOUT_BASE_URL=https://www.mannatenterprises.shop

# Deep link back to the app after payment verification
APP_RETURN_DEEP_LINK=zztherapy://wallet

# CORS
# Comma-separated list of allowed web origins. Supports wildcards like https://*.example.com
CORS_ORIGIN=https://www.mannatenterprises.shop,https://mannatenterprises.lovable.app

# Auth / sessions
JWT_SECRET=change_me
CHECKOUT_SESSION_SECRET=change_me

# Firebase Admin (still needed for ID-token verification, account deletion, Stream FCM)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Cloudflare Images (image delivery + uploads)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_ACCOUNT_HASH=your_cloudflare_account_hash
CLOUDFLARE_IMAGES_API_TOKEN=your_cloudflare_images_api_token
CLOUDFLARE_IMAGES_DELIVERY_HOST=imagedelivery.net
CLOUDFLARE_IMAGES_MAX_UPLOAD_BYTES=10485760

# Image upload anti-abuse quotas (Redis counters)
IMAGE_QUOTA_AVATAR_PER_DAY=15
IMAGE_QUOTA_GALLERY_PER_HOUR=60

# Image pipeline background workers (optional tuning; safe defaults shipped).
#  - IMAGE_ORPHAN_CRON_MS:   how often orphan-asset cleanup runs (default 30 min).
#  - IMAGE_ORPHAN_BATCH_SIZE: max orphans deleted per tick (default 50).
#  - BLURHASH_CONCURRENCY:    parallel blurhash workers (default 2; keep low,
#                             sharp() is CPU-heavy).
# IMAGE_ORPHAN_CRON_MS=1800000
# IMAGE_ORPHAN_BATCH_SIZE=50
# BLURHASH_CONCURRENCY=2

# Onboarding rollout (optional)
# ONBOARDING_STRICT_MODE=log-only
# ONBOARDING_FAST_FORWARD_UNTIL=2026-06-02T00:00:00.000Z
# MIN_FIXED_CLIENT_VERSION=1.2.0

# Feature flag: gate the Cloudflare Images path. Set to "true" once snapshot tests + smoke pass.
# When "false" or unset, the /images/* endpoints return 503 and legacy paths stay active.
# IMPORTANT: This flag must be flipped in BOTH backend AND frontend env at the
# same time. The frontend reads `USE_CLOUDFLARE_IMAGES` from its own dotenv file
# (see frontend/.env.example).
USE_CLOUDFLARE_IMAGES=false

# Moments + Cloudflare Stream (reels / stories)
USE_MOMENTS=false
# free = all moments unlocked for authenticated users; paid = Moments Premium subscription
MOMENTS_ACCESS_MODE=paid
USE_CLOUDFLARE_STREAM=false
MOMENTS_CREATOR_REVENUE_SHARE=0.5
# Coins credited to creator wallet when they upload a moment (one-time per post)
MOMENTS_PHOTO_UPLOAD_REWARD_COINS=10
MOMENTS_VIDEO_UPLOAD_REWARD_COINS=30
MOMENTS_ENTITLEMENT_VERSION=1
MOMENTS_STORY_IMAGE_MAX_BYTES=10485760
MOMENTS_STORY_VIDEO_MAX_SECONDS=90
MOMENTS_REEL_IMAGE_MAX_BYTES=20971520
MOMENTS_REEL_VIDEO_MAX_SECONDS=180
MOMENTS_PURCHASE_LOCK_TTL_SEC=8
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_STREAM_CUSTOMER_CODE=
CLOUDFLARE_STREAM_SIGNING_KEY_ID=
CLOUDFLARE_STREAM_SIGNING_KEY_JWK=
CLOUDFLARE_STREAM_WEBHOOK_SECRET=
# Webhook URL: https://prestigeinteriordesign.com/api/v1/stream/webhook

# New Moments API helpers (Flutter UI):
# GET  /moments/creators/:creatorId/summary
# GET  /moments/creator/me
# GET  /stories/creator/me
MOMENTS_RATE_LIMIT_PURCHASE_MAX=5
MOMENTS_RATE_LIMIT_FOLLOW_MAX=30
MOMENTS_RATE_LIMIT_UPLOAD_MAX=20
MOMENTS_RATE_LIMIT_STORY_VIEW_MAX=120

# Feed fanout + warmers (Phase 2) — enable gradually; see docs/moments-ops-runbook.md
MOMENTS_FANOUT_ON_UPLOAD=false
MOMENTS_FEED_WARMER=false
MOMENTS_FEED_WARMER_FOLLOWER_THRESHOLD=1000
MOMENTS_FEED_WARMER_TOP_FOLLOWERS=50
MOMENTS_FOLLOWING_FEED_CACHE_TTL_SEC=604800
MOMENTS_FEED_CACHE_TTL_SEC=30
# Alert when moments:fanout:queue LLEN exceeds this (GET /metrics)
MOMENTS_FANOUT_QUEUE_ALERT_DEPTH=500

# Cloudflare Stream circuit breaker
CF_STREAM_BREAKER_THRESHOLD=5
CF_STREAM_BREAKER_RESET_MS=30000
CF_STREAM_RETRY_MAX=3
CF_STREAM_DEGRADED_MODE=true

# Moderation: when "true", new uploads start as 'pending' and hide until approved.
# When "false"/unset, uploads are 'auto-ok' by default.
IMAGE_MODERATION_PENDING_BY_DEFAULT=false

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx
# Configure a second webhook URL for VIP membership purchases:
# POST {PUBLIC_API_BASE_URL}/vip/webhook
# Filter events where order notes.productType === 'vip_membership'

# Welcome free call — first-call promo for new users (not wallet coins).
# FREE_CALL_ENABLED: master switch (true/false). When false, no new grants and no promo billing.
# FREE_CALL_DURATION_SECONDS: length of the free call — must be 15, 30, or 45.
FREE_CALL_ENABLED=true
FREE_CALL_DURATION_SECONDS=30

# VIP membership (consumer role === 'user' only) — opt-in: set VIP_ENABLED=true to unlock
VIP_ENABLED=false
VIP_SCHEDULING_ENABLED=false
VIP_PRIORITY_QUEUE_ENABLED=false
VIP_RECHARGE_BONUS_ENABLED=false
VIP_PROFILE_FRAME_ENABLED=false
VIP_SUPPORT_ENABLED=false
VIP_RECHARGE_BONUS_BPS=1000
VIP_PRICE_INR=499
VIP_DURATION_DAYS=30
VIP_FREE_MOMENTS_PER_DAY=10
VIP_RECHARGE_DISCOUNT_BPS=1000
VIP_MOMENT_DISCOUNT_BPS=1000
VIP_CALL_QUEUE_TTL_SEC=900
VIP_SCHEDULE_MIN_LEAD_MINUTES=30
VIP_SCHEDULE_MAX_DAYS_AHEAD=7
VIP_RECONCILIATION_INTERVAL_MS=60000
VIP_APP_RETURN_DEEP_LINK=zztherapy://vip
MOMENTS_PREMIUM_APP_RETURN_DEEP_LINK=zztherapy://moments-plan
# Optional web fallback for GET /moments/:id/share (Flutter share text uses deepLink + PLAY_STORE_URL).
# Do NOT point at mannatenterprises unless you host a /moment redirect page there.
# MOMENT_SHARE_BASE_URL=https://www.matchvibe.app/moment
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.matchvibe.app&pcampaignid=web_share
MOMENT_APP_DEEP_LINK_SCHEME=zztherapy
MOMENTS_RATE_LIMIT_COMMENT_MAX=30
MOMENTS_RATE_LIMIT_COMMENT_WINDOW_SEC=3600

# Mongo
MONGO_URI=mongodb+srv://...

# Windows local dev only (AVG/AV HTTPS scan + MongoDB SRV DNS). See ../scripts/windows-trust-dev-ca.ps1
# LOAD_TEST_DNS_SERVERS=8.8.8.8,8.8.4.4
# NODE_EXTRA_CA_CERTS=D:\zztherapy\dev-certs\intercept-root.pem

# Redis (required in production for billing + metrics)
REDIS_URL=redis://default:password@host:6379
REDIS_PUBLIC_URL=redis://default:password@public-host:13225
REDIS_PASSWORD=password
REDISHOST=redis.railway.internal
REDISPORT=6379
REDISUSER=default

# Billing — creator share of listed price/min (0.25 = 25%). Override anytime.
CREATOR_SHARE_PERCENTAGE=0.25

# Presence + billing recovery (production recommended)
# Canonical creator presence states emitted to clients:
#   online | on_call | offline
BILLING_SYNC_WARNING_CONNECTED_AUTOHEAL_THRESHOLD=1
CREATOR_DISCONNECT_GRACE_MS=3000
# Ringing grace: treat fresh active-call slots as live before Mongo Call row exists (default 120s)
# RINGING_SLOT_GRACE_SECONDS=120
# Reconciliation sweep min slot age before clearing orphans (default RINGING_SLOT_GRACE_SECONDS + 60)
# PRESENCE_SLOT_SWEEP_MIN_AGE_SECONDS=180

# Multi-node creator presence (required on all api-ws tasks when running >1 replica)
# PRESENCE_REDIS_SOCKET_REGISTRY_ENABLED=true
# PRESENCE_REGISTRY_SHADOW=true
# CREATOR_PRESENCE_TTL_SECONDS=180
# CREATOR_HEARTBEAT_INTERVAL_MS=45000
# CREATOR_DISCONNECT_GRACE_MS=3000

# Phase 4 — creator feed rank (default off; shadow/canary rollout)
# CREATOR_FEED_REDIS_RANK_ENABLED=false
# CREATOR_FEED_RANK_SHADOW=false
# CREATOR_FEED_RANK_REBUILD=false
# CREATOR_FEED_AVAILABILITY_MAX_CATALOG=8000

# Phase 4 — admin performance pagination
# ADMIN_PERFORMANCE_INCLUDE_IDLE_DAYS=90

# Phase 5 — billing instance id (auto from ECS_CONTAINER_METADATA_URI_V4 if unset)
# BILLING_INSTANCE_ID=
BILLING_RECOVERY_DEBOUNCE_MS=750
BILLING_RECOVERY_EMPTY_DEBOUNCE_MS=2000
BILLING_RECOVERY_EMPTY_CACHE_TTL_SECONDS=3

# Durable CallSession phased rollout (A→B→C→D)
# DURABLE_CALL_SESSION_ENABLED=false
# BILLING_OWNERSHIP_V2_ENABLED=false
# INCREMENTAL_BILLING_PERSIST_ENABLED=false
# BILLING_OUTBOX_PROJECTION_ENABLED=false
# BILLING_WATCHDOG_AUTO_FINALIZE_ENABLED=false
# CALL_SESSION_MIRROR_INTERVAL_MS=5000
# CALL_SESSION_LEASE_TTL_MS=15000
# BILLING_PERSIST_INTERVAL_MS=5000
# BILLING_LEDGER_GAP_TOLERANCE_MS=2000
# SOCKETIO_CLOSE_MS=15000
# BILLING_PROCESS_INTERVAL_MS=1000

# Call reconciliation tuning (safe defaults are applied if unset).
# Keep these explicit during rollout to control scan pressure and restore behavior.
# CALL_RECONCILIATION_INTERVAL_MS=300000
# CALL_RECONCILIATION_PARALLELISM=6
# CALL_RECONCILIATION_BATCH_PAUSE_MS=100
# CALL_RECONCILIATION_SETTLED_RESTORE_AGE_MS=30000
# CALL_RECON_UNSETTLED_LOOKBACK_MS=604800000
