############################################
# Backend env template (DO NOT put secrets in git)
############################################

# Runtime
NODE_ENV=production
PORT=3000
TRUST_PROXY_HOPS=1

# Public URLs (used to build web checkout links)
# This MUST be your public API base including /api/v1
PUBLIC_API_BASE_URL=https://api.yourdomain.com/api/v1

# This MUST be the public website host that serves /wallet-checkout
WEB_CHECKOUT_BASE_URL=https://www.mannatenterprises.shop

# Deep link back to the app after payment verification
APP_RETURN_DEEP_LINK=zztherapy://wallet

# CORS
# Comma-separated list of allowed web origins. Supports wildcards like https://*.example.com
CORS_ORIGIN=https://www.mannatenterprises.shop,https://mannatenterprises.lovable.app

# Auth / sessions
JWT_SECRET=change_me
CHECKOUT_SESSION_SECRET=change_me

# Firebase Admin
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx

# Mongo
MONGO_URI=mongodb+srv://...

# Redis (required in production for billing + metrics)
REDIS_URL=redis://default:password@host:6379
REDIS_PUBLIC_URL=redis://default:password@public-host:13225
REDIS_PASSWORD=password
REDISHOST=redis.railway.internal
REDISPORT=6379
REDISUSER=default
