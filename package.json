{
  "name": "eazy-talks-backend",
  "version": "1.0.0",
  "description": "Backend API for Eazy Talks mobile app",
  "main": "dist/server.js",
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev.ps1",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "tsx --test src/modules/payment/commission-resolve.service.test.ts src/modules/billing/billing.queue.contract.test.ts src/modules/billing/billing.flush.contract.test.ts src/modules/billing/billing.idempotency.contract.test.ts src/modules/video/video.webhook.routes.contract.test.ts src/modules/video/creator-availability.contract.test.ts src/modules/creator/creator-promotion-ledger.contract.test.ts src/modules/creator/creator-feed.contract.test.ts src/modules/admin/creator-transfer.contract.test.ts src/modules/admin/admin-dashboard.contract.test.ts src/modules/admin/admin-agency.contract.test.ts src/modules/payment/payment.webhook.contract.test.ts src/middlewares/webhook-signature.contract.test.ts src/modules/agency/agency.withdrawals.contract.test.ts src/modules/agency/agency.password.contract.test.ts src/scripts/hierarchy-swap.migration.contract.test.ts src/scripts/hierarchy-invalidation-shim.contract.test.ts src/scripts/hierarchy-verify.contract.test.ts src/modules/creator/creator.withdrawal.contract.test.ts src/modules/availability/creator-daily-online.service.test.ts src/modules/creator/creator-tasks.config.test.ts src/modules/images/__tests__/serialization.snapshot.test.ts src/modules/images/__tests__/contract.snapshot.test.ts src/modules/metrics/__tests__/image-render-metrics.contract.test.ts",
    "guard:hierarchy-legacy": "node scripts/check-hierarchy-legacy.cjs",
    "seed:admin": "tsx src/scripts/seed-admin.ts",
    "migrate:identity-ledger": "tsx src/scripts/backfill-identity-ledger.ts",
    "migrate:agency-bd-swap": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/with-dev-env.ps1 tsx src/scripts/migrate-agency-bd-hierarchy-swap.ts",
    "verify:agency-bd-swap": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/with-dev-env.ps1 tsx src/scripts/verify-agency-bd-hierarchy-swap.ts",
    "seed:preset-avatars-cloudflare": "tsx src/scripts/seed-preset-avatars-cloudflare.ts",
    "bootstrap:cloudflare-variants": "tsx src/scripts/cloudflare-bootstrap-variants.ts",
    "upload:ringtone": "tsx src/scripts/upload-ringtone.ts",
    "guard:flutter-payment-boundary": "node scripts/check-flutter-payment-boundary.cjs",
    "verify:redis": "tsx scripts/verify-redis.ts",
    "backfill:referral-edges": "tsx src/scripts/backfill-referral-edges.ts",
    "reconcile:withdrawal-assignment": "tsx src/scripts/reconcile-unassigned-withdrawals.ts",
    "resync:stream-images": "tsx src/scripts/resync-stream-user-images.ts",
    "check:phone-login-users": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/with-dev-env.ps1 node ./node_modules/tsx/dist/cli.mjs src/scripts/check-phone-login-users.ts",
    "backfill:agency-approved-creators": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/with-dev-env.ps1 tsx src/scripts/backfill-agency-approved-to-creators.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@stream-io/node-sdk": "^0.7.40",
    "@types/jsonwebtoken": "^9.0.10",
    "@upstash/redis": "^1.36.2",
    "axios": "^1.13.4",
    "bcrypt": "^6.0.0",
    "blurhash": "^2.0.5",
    "bullmq": "^5.73.4",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "file-type": "^19.6.0",
    "firebase-admin": "^12.0.0",
    "form-data": "^4.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.3",
    "opossum": "^8.4.0",
    "rate-limit-redis": "^4.3.1",
    "razorpay": "^2.9.6",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3",
    "stream-chat": "^8.60.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/opossum": "^8.1.8",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
