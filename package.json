    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "mongodb-memory-server": "^10.1.4",
    "supertest": "^7.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
