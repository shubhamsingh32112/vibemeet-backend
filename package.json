    "test:billing-shadow": "tsx --test src/tests/billing-domain-shadow.test.ts",
    "type-check": "tsc --noEmit",
    "seed:admin": "tsx src/scripts/seed-admin.ts",
    "seed:preset-avatars": "tsx src/scripts/upload-preset-avatars.ts",
    "upload:ringtone": "tsx src/scripts/upload-ringtone.ts",
    "upload:coin-images": "tsx src/scripts/upload-coin-images.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
